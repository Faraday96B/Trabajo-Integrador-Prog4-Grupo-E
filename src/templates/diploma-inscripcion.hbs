<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <title>{{titulo}}</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      color: #0f172a;
      font-family: Arial, Helvetica, sans-serif;
      margin: 0;
    }

    .document {
      border: 3px solid #0052db;
      min-height: 100vh;
      padding: 42px;
      position: relative;
    }

    .header {
      align-items: flex-start;
      border-bottom: 1px solid #dbe4f0;
      display: flex;
      justify-content: space-between;
      padding-bottom: 24px;
    }

    .brand {
      color: #0052db;
      font-size: 22px;
      font-weight: 800;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .subtitle {
      color: #475569;
      font-size: 14px;
      margin-top: 6px;
    }

    .meta {
      color: #475569;
      font-size: 13px;
      text-align: right;
    }

    .content {
      padding: 70px 28px 52px;
      text-align: center;
    }

    .kicker {
      color: #0052db;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    h1 {
      font-size: 40px;
      line-height: 1.15;
      margin: 18px 0 34px;
    }

    .lead {
      color: #334155;
      font-size: 18px;
      line-height: 1.6;
      margin: 0 auto;
      max-width: 660px;
    }

    .student {
      border-bottom: 2px solid #0052db;
      display: inline-block;
      font-size: 30px;
      font-weight: 800;
      margin: 30px 0 26px;
      padding: 0 24px 10px;
    }

    .course {
      color: #0f172a;
      font-size: 24px;
      font-weight: 800;
      margin-top: 18px;
    }

    .details {
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(2, 1fr);
      margin-top: 54px;
      text-align: left;
    }

    .detail {
      background: #f8fafc;
      border: 1px solid #dbe4f0;
      border-radius: 8px;
      padding: 16px;
    }

    .detail span {
      color: #64748b;
      display: block;
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 8px;
      text-transform: uppercase;
    }

    .detail strong {
      font-size: 16px;
    }

    .footer {
      bottom: 42px;
      color: #64748b;
      font-size: 13px;
      left: 42px;
      position: absolute;
      right: 42px;
      text-align: center;
    }
  </style>
</head>
<body>
  <main class="document">
    <header class="header">
      <div>
        <div class="brand">FCAD - UNER</div>
        <div class="subtitle">Sistema de Inscripcion a Cursos</div>
      </div>
      <div class="meta">
        ID de inscripcion: <strong>{{idInscripcion}}</strong><br>
        Fecha de emision: <strong>{{fechaEmision}}</strong>
      </div>
    </header>

    <section class="content">
      <div class="kicker">{{titulo}}</div>
      <h1>Diploma de inscripcion</h1>
      <p class="lead">Se deja constancia de que el/la estudiante</p>
      <div class="student">{{estudianteNombre}}</div>
      <p class="lead">Documento {{documento}}, registra una inscripcion al curso</p>
      <div class="course">{{nombreCurso}}</div>

      <div class="details">
        <div class="detail">
          <span>Fecha de inscripcion</span>
          <strong>{{fechaInscripcion}}</strong>
        </div>
        <div class="detail">
          <span>Estado de inscripcion</span>
          <strong>{{estadoInscripcion}}</strong>
        </div>
        <div class="detail">
          <span>Fecha de inicio del curso</span>
          <strong>{{fechaInicio}}</strong>
        </div>
        <div class="detail">
          <span>Carga horaria</span>
          <strong>{{cantidadHoras}} horas</strong>
        </div>
      </div>
    </section>

    <footer class="footer">Documento generado automaticamente por el sistema.</footer>
  </main>
</body>
</html>
